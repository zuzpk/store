{
  "name": "@zuzjs/store",
  "version": "0.1.8",
  "keywords": [
    "react",
    "zuz",
    "zuz.js",
    "zuz store"
  ],
  "description": "ZuzJS State Manager",
  "author": "Zuz.js Team <support@zuz.com.pk>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev:js": "tsup --watch",
    "dev": "npm-run-all -p dev:*",
    "build": "rm -rf dist && tsup",
    "publish": "npm run build && node publish-pre.js && npm publish && node publish-post.js"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "react": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}